# ==========================================================================
# Taller Villanueva — variables de entorno
# ==========================================================================

# --- Base de datos (Supabase / Postgres) ---------------------------------
# RUNTIME: usa el pooler de Supabase (Supavisor), puerto 6543, con pgbouncer.
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# MIGRACIONES: conexión directa, puerto 5432 (Prisma migrate la necesita).
DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Autenticación (custom: usuario + bcrypt + JWT propio) ----------------
# Secreto para firmar el JWT de sesión. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# Duración de la sesión (segundos). 8 horas por defecto.
AUTH_SESSION_MAX_AGE="28800"

# --- Supabase (OPCIONAL) --------------------------------------------------
# Solo si más adelante usas Storage, Realtime o el REST API de Supabase.
# La app NO los requiere para funcionar (el acceso a datos es vía Prisma).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
